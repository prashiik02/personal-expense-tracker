# Copy to .env and fill in values:
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env  (Windows)

FLASK_ENV=development
SECRET_KEY=change-me-use-a-long-random-string
JWT_SECRET_KEY=change-me-use-a-long-random-string

# SQLite (default): omit this line to use backend/instance/auth_app.db
# SQLALCHEMY_DATABASE_URI=sqlite:///C:/absolute/path/to/db.sqlite

# MySQL (optional — set all five DB_* vars; leave SQLALCHEMY_DATABASE_URI unset)
# DB_USER=
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=

CATEGORIZER_DATA_DIR=.data
CATEGORIZER_MODEL_PATH=.data/cat_model.pkl
CATEGORIZER_FEEDBACK_PATH=.data/feedback_store.json
CUSTOM_CATEGORIES_PATH=.data/custom_categories.json

# DeepSeek — required for Assistant and optional LLM categorization fallback
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Categorization LLM fallback (single txn / SMS when ML is unsure)
LLM_CATEGORIZATION_ENABLED=true
LLM_MIN_CONFIDENCE=0.62

# Optional: Gemini for long PDF / chunked batch (set GEMINI_API_KEY to prefer Gemini for chunks)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
